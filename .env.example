# ── WineBot Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# NEVER commit .env to version control.

# ── API ─────────────────────────────────────────────────────────────────────
# API authentication token (auto-generated if empty)
INFRA_WINEBOT_API_TOKEN=

# API URL (for sidecar callback)
INFRA_WINEBOT_API_URL=http://localhost:8000

# CV Sidecar URL
INFRA_WINEBOT_SIDECAR_URL=http://localhost:8001

# ── VNC ─────────────────────────────────────────────────────────────────────
# VNC/noVNC passwords (defaults to "winebot" if unset)
INFRA_VNC_PASSWORD=
INFRA_NOVNC_PASSWORD=

# ── GitHub Container Registry ──────────────────────────────────────────────
# For CI/CD image publishing
INFRA_GHCR_TOKEN=

# ── Docker ─────────────────────────────────────────────────────────────────
# Docker bridge gateway IP (auto-detected in container; override for custom networks)
INFRA_DOCKER_GATEWAY=172.17.0.1

# ── Cloud Services ─────────────────────────────────────────────────────────
INFRA_CLOUDFLARE_TOKEN=
INFRA_UPTIMEROBOT_APIKEY=

# ── Deployment (Linux server) ──────────────────────────────────────────────
# TrueNAS / GPU server connection details
INFRA_TRUENAS_HOST=
INFRA_TRUENAS_GPU_0=
INFRA_TRUENAS_GPU_1=

# ── Model Registry ─────────────────────────────────────────────────────────
# HF token for authenticated model downloads
INFRA_HF_TOKEN=

# ── Ollama ─────────────────────────────────────────────────────────────────
INFRA_OLLAMA_HOST=http://localhost:30068

# ── Captioning Sidecar ─────────────────────────────────────────────────────
INFRA_CAPTIONING_SIDECAR_URL=http://localhost:8002
