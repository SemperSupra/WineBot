# ── WineBot Deploy Credentials ─────────────────────────────────────────────
# Copy to /etc/winebot-credentials on the deployment server.
#   sudo cp deploy/credentials.template /etc/winebot-credentials
#   sudo chown root:root /etc/winebot-credentials
#   sudo chmod 600 /etc/winebot-credentials
#
# These variables are sourced by systemd services and entrypoint scripts.
# The .env file at the repo root is for local development only.

# ── API ─────────────────────────────────────────────────────────────────────
# API authentication token used by sidecar ↔ API communication.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
export INFRA_WINEBOT_API_TOKEN=""

# ── VNC ─────────────────────────────────────────────────────────────────────
# VNC/noVNC passwords for remote desktop access.
export INFRA_VNC_PASSWORD=""
export INFRA_NOVNC_PASSWORD=""

# ── Docker Registry ────────────────────────────────────────────────────────
# GitHub Container Registry token for publishing images.
export INFRA_GHCR_TOKEN=""

# ── Service URLs ────────────────────────────────────────────────────────────
# Internal service endpoints (typically localhost for same-host deployment).
export INFRA_WINEBOT_API_URL="http://localhost:8000"
export INFRA_WINEBOT_SIDECAR_URL="http://localhost:8001"
export INFRA_OLLAMA_HOST="http://localhost:30068"
export INFRA_CAPTIONING_SIDECAR_URL="http://localhost:8002"

# ── Cloudflare (optional) ──────────────────────────────────────────────────
# API token for Cloudflare DNS/tunnel management.
export INFRA_CLOUDFLARE_TOKEN=""

# ── UptimeRobot (optional) ─────────────────────────────────────────────────
# API key for monitoring service.
export INFRA_UPTIMEROBOT_APIKEY=""
