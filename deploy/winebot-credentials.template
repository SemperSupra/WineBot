# ── WineBot Deploy Credentials ──────────────────────────────────────────────
# Copy to /etc/winebot-credentials on the deployment server.
#   sudo cp winebot-credentials.template /etc/winebot-credentials
#   sudo chown root:root /etc/winebot-credentials
#   sudo chmod 600 /etc/winebot-credentials
#
# Then source from systemd service or startup script:
#   set -a; source /etc/winebot-credentials; set +a

# ── API ─────────────────────────────────────────────────────────────────────
INFRA_WINEBOT_API_TOKEN=change-me-to-a-random-secret
INFRA_WINEBOT_API_URL=http://localhost:8000
INFRA_WINEBOT_SIDECAR_URL=http://localhost:8001

# ── VNC (optional — set to lock VNC access) ────────────────────────────────
INFRA_VNC_PASSWORD=
INFRA_NOVNC_PASSWORD=

# ── GitHub Container Registry ──────────────────────────────────────────────
INFRA_GHCR_TOKEN=change-me

# ── Cloud Services (optional) ──────────────────────────────────────────────
INFRA_CLOUDFLARE_TOKEN=
INFRA_UPTIMEROBOT_APIKEY=
INFRA_HF_TOKEN=

# ── Ollama / Captioning (optional, TrueNAS GPU servers) ────────────────────
INFRA_OLLAMA_HOST=http://localhost:30068
INFRA_CAPTIONING_SIDECAR_URL=http://localhost:8002
