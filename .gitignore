# Local apps/executables
/apps/*
!/apps/.gitkeep

# Local environment overrides
.env
.env.*

# Python cache
__pycache__/
*.pyc

# Editor/OS noise
.DS_Store
.idea/
.vscode/

# Local archives
WineBot-codex-starter-files.zip

# Artifacts (keep empty dir)
/artifacts/*
!/artifacts/.gitkeep
session.md

# Generated screenshots and eval data
Screenshot *.png
/models/eval/
/models/yolo/*.pt
/models/tessdata/*.traineddata

# Training datasets (regenerated from winebot-gt-generator.py)
/models/wine-dataset/
/models/wine-dataset-gen/

# Deploy credentials (never commit)
/etc/winebot-credentials
/etc/winebot-credentials.template

# Cross-validation output (regenerated on demand)
/models/cross-validation/

# Competitive research artifacts (→ private repo: mark-e-deyoung/winebot-research)
/STATUS.md
/docs/BUILD_LADDER.md
